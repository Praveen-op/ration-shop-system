# ─────────────────────────────────────────
#  TNCS Ration Shop — Environment Variables
#  Copy this file to .env and fill values
# ─────────────────────────────────────────

# MongoDB connection string
# Local:   mongodb://localhost:27017/rationshop
# Atlas:   mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/rationshop
MONGO_URI=mongodb://localhost:27017/rationshop

# Server port
PORT=3000
